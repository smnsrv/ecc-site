# Скопируйте в `.env` (не в git). Только для npm run dev — CTA/тест Telegram через Vite-прокси.
# В проде: Google Apps Script — свойства TG_TOKEN и TG_CHAT_ID.
# Несколько получателей: 111,222 или 111|222 (GAS: то же, разделители , ; |)

VITE_TG_TOKEN=
VITE_TG_CHAT_ID=

# SEO: каноничный origin без слэша на конце (для og:url, JSON-LD при npm run build).
# Пример: VITE_SITE_ORIGIN=https://username.github.io/repo-name
# VITE_SITE_ORIGIN=

# Google Analytics 4: поток из GA → настройки потока → ID вида G-XXXXXXXX
# VITE_GA_MEASUREMENT_ID=
